# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=rutracker
DB_PASSWORD=rutracker
DB_NAME=rutracker
DB_SSLMODE=disable

# Server
SERVER_ADDR=:8080

# Migrator
# Path to the rutracker XML archive (can also be passed via -file flag)
MIGRATOR_FILE=
# Number of torrents per batch insert
MIGRATOR_BATCH_SIZE=2000
# Print progress every N records
MIGRATOR_PROGRESS=10000
